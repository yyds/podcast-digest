# YouTube Data API — https://console.cloud.google.com → APIs & Services → Credentials
YOUTUBE_API_KEY=

# Gemini — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Groq (for podcast transcription) — https://console.groq.com/keys
GROQ_API_KEY=

# DeepSeek (for Chinese podcast summaries) — https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Gmail — use an App Password, not your real password
# https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=

# Who receives the digest (add a second email if you want)
RECIPIENT_EMAIL=
RECIPIENT_EMAIL_2=
